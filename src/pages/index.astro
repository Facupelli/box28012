---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import BaseLayout from "../layouts/layout.astro";
import WhatsAppLink from "../components/whatsapp-link.astro";
import MainNav from "../components/main-nav.astro";
import HeroImage from "../assets/images/hero.webp";
import BoxImage from "../assets/images/box.webp";
import BathImage from "../assets/images/bath.webp";
import RemerasImage from "../assets/images/remeras.webp";
import { getHomeData } from "../data/home";
import Activities from "../components/activities.astro";

const data = getHomeData();
const {
	activities,
	aboutParagraphs,
	businessInfo,
	pricingPlans,
	contactItems,
} = data;
---

<BaseLayout
	title="Box 28012. Madrid."
	description="Box 28012 es un espacio de entrenamiento funcional en Madrid centro con grupos reducidos, técnica y atención personalizada."
>
	<MainNav />

	<div class="relative overflow-hidden">
		<!-- INTRO/HERO -->
		<div class="max-w-600 mx-auto">
			<section
				id="inicio"
				class="relative h-[calc(100svh-80px)] mt-20 md:mt-0 md:h-svh px-4 md:px-10 lg:px-20 py-6 md:py-20 w-full"
			>
				<div
					class="flex flex-col-reverse md:flex-row h-full w-full items-center gap-8 md:gap-20"
				>
					<div
						class="flex flex-col gap-4 md:gap-8 md:min-w-120 w-full md:w-auto"
					>
						<h1>
							<span class="block text-brand">
								{businessInfo.name}
							</span>
							<!-- <span class="block text-brand-kicker pt-1">
								{businessInfo.city}
							</span> -->
						</h1>

						<div class="space-y-1 text-pretty">
							<h2 class="text-lead text-text">
								Entrenamiento funcional en el corazón de Madrid.
							</h2>
							<p class="text-lead">
								Grupos reducidos, corrección técnica y sesiones adaptadas a tu
								nivel.
							</p>
						</div>

						<div class="pt-6 md:pt-0">
							<WhatsAppLink>
								<Icon name="whatsapp" class="size-7" aria-hidden="true" />
								<div class="flex items-center gap-4">
									Reserva tu primera sesión gratis
									<Icon
										name="arrow-right"
										class="size-5 text-accent hidden md:block"
										aria-hidden="true"
									/>
								</div>
							</WhatsAppLink>
						</div>
					</div>

					<div class="w-full flex items-center h-full">
						<Image
							src={HeroImage}
							alt="Salón principal del Box 28012"
							class="w-full object-cover"
						/>
					</div>
				</div>

				<div class="hidden lg:block absolute right-10 bottom-10">
					<div class="flex items-center gap-2">
						<span class="text-muted">{businessInfo.fullAddress}</span>
						<div class="h-px bg-muted w-20"></div>
					</div>
				</div>
			</section>
		</div>

		<!-- ACTIVIDADES -->
		<div class="max-w-400 mx-auto">
			<section id="actividades" class="px-4 md:px-10 py-14 md:py-30">
				<div class="space-y-2">
					<h2 class="text-section-title">ACTIVIDADES</h2>
					<p class="text-lead">
						Sesiones variadas, adaptadas a distintos niveles y objetivos.
					</p>
				</div>

				<Activities />
			</section>
		</div>

		<!-- SOBRE EL BOX -->
		<div class="max-w-400 mx-auto">
			<section
				id="el-box"
				class="relative isolate grid max-w-430 gap-10 md:gap-20 lg:min-h-125 lg:grid-cols-[0.9fr_2.25fr] px-4 md:px-10 py-14 md:py-30"
			>
				<div class="space-y-4 md:space-y-6 md:pt-30">
					<div class="h-1 bg-accent w-12"></div>
					<h2 class="text-section-title">SOBRE EL BOX</h2>
					<div class="text-body space-y-4">
						{aboutParagraphs.map((paragraph) => <p>{paragraph}</p>)}
					</div>
				</div>

				<div class="grid grid-cols-2 gap-2 sm:relative sm:block sm:min-h-215">
					<!-- Large image: full-width on mobile, absolute on desktop -->
					<figure
						class="col-span-2 overflow-hidden bg-black ring-1 ring-white/8
           sm:absolute sm:bottom-0 sm:right-20 sm:z-10 sm:h-210 sm:w-160
           shadow-[0_18px_50px_rgba(0,0,0,0.38)]"
					>
						<Image
							src={BathImage}
							alt="Vestuarios oscuros con azulejos negros y detalles rojos"
							class="h-100 md:h-full w-full object-cover"
						/>
					</figure>

					<!-- Bottom-left image: half-width on mobile, absolute on desktop -->
					<figure
						class="overflow-hidden bg-black ring-1 ring-white/10
           sm:absolute sm:bottom-0 sm:left-0 sm:z-20 sm:h-130 sm:w-90"
					>
						<Image
							src={BoxImage}
							alt="Zona de entrenamiento con barra en Box 28012"
							class="h-full w-full object-cover"
						/>
					</figure>

					<!-- Bottom-right image: half-width on mobile, absolute on desktop -->
					<figure
						class="overflow-hidden bg-black ring-1 ring-white/10
           sm:absolute sm:bottom-0 sm:right-0 sm:z-30 sm:h-80 sm:w-80"
					>
						<Image
							src={RemerasImage}
							alt="Camisetas negras de Box 28012 colgadas en un perchero"
							class="h-full w-full object-cover sm:h-70 lg:h-80"
						/>
					</figure>
				</div>

				<div
					aria-hidden="true"
					class="pointer-events-none absolute h-[70%] w-[80%] md:w-[40%] -translate-y-1/2 top-1/2 left-1/2 md:left-0 -translate-x-1/2 md:translate-x-0 inset-0 opacity-40
           bg-[radial-gradient(rgba(255,255,255,0.22)_1px,transparent_1px)]
           bg-size-[28px_28px]"
				>
				</div>
			</section>
		</div>

		<!-- TARIFAS -->
		<div class="max-w-400 mx-auto">
			<section
				id="tarifas"
				class="grid grid-cols-1 gap-10 px-4 py-14 md:grid-cols-[minmax(16rem,0.35fr)_minmax(0,0.65fr)] md:gap-12 md:px-10 md:py-30 lg:gap-16"
			>
				<div class="space-y-2 pt-10">
					<h2 class="text-section-title">Tarifas Trimestrales</h2>

					<div class="max-w-110 pt-4 pb-4 space-y-2 md:pt-8">
						<p class="text-lead text-text">Sin Matrícula. Sin permanencia</p>
						<p class="text-body">
							Escríbenos y te ayudamos a elegir la tarifa que mejor se adapte a
							tus objetivos.
						</p>
					</div>

					<WhatsAppLink>
						Consultar por WhatsApp
						<Icon
							name="arrow-right"
							class="size-5 text-accent"
							aria-hidden="true"
						/>
					</WhatsAppLink>
				</div>

				<div class="grid min-w-0 content-center">
					{
						pricingPlans.map((plan) => (
							<article
								class:list={[
									"grid min-w-0 grid-cols-[3rem_1px_minmax(0,1fr)] gap-x-5 border-b border-white/10 md:py-8 py-6 last:border-b-0",
									"md:min-h-24 md:grid-cols-[3rem_1px_minmax(9rem,1fr)_7rem_minmax(9rem,1.2fr)] md:items-center md:gap-6 md:py-8",
									"lg:grid-cols-[3.5rem_1px_minmax(11rem,1fr)_8rem_minmax(11rem,1.2fr)] lg:gap-8",
									"xl:grid-cols-[4rem_1px_minmax(13rem,1fr)_9rem_minmax(13rem,1.2fr)] xl:gap-10",
									"2xl:grid-cols-[5rem_1px_minmax(16rem,1fr)_11rem_minmax(16rem,1.2fr)] 2xl:gap-10",
								]}
							>
								<span class="pt-1 text-lg font-bold leading-none text-accent md:pt-0 md:text-xl">
									{plan.number}
								</span>

								<span class="h-full min-h-22 w-px bg-white/20 md:h-8 md:min-h-0" />

								<div class="min-w-0 md:contents space-y-1 md:space-y-0">
									<h3 class="text-base font-normal uppercase leading-none tracking-wide text-text md:text-xl lg:text-2xl">
										{plan.name}.
									</h3>

									<p class="text-price font-normal text-text">{plan.price}</p>

									<p class="text-xs uppercase leading-tight tracking-wide text-subtle md:text-sm lg:text-base">
										{plan.detail}
									</p>
								</div>
							</article>
						))
					}
				</div>
			</section>
		</div>

		<!-- PONTE EN CONTACTO -->
		<section id="contacto" class="isolate py-14 md:py-30">
			<div class="max-w-400 mx-auto px-4 md:px-10">
				<div class="space-y-10">
					<div class="space-y-6">
						<div>
							<p class="text-lead max-w-150 text-pretty text-muted pb-4">
								En Box 28012 entrenamos en grupos reducidos para ofrecerte una
								experiencia totalmente personalizada.
							</p>
							<div class="h-0.5 bg-accent w-12"></div>
						</div>

						<div class="space-y-4">
							<h2 class="text-section-title">¿Tienes alguna duda?</h2>
							<p class="text-lead">
								Escríbenos por WhatsApp para consultar horarios, resolver dudas
								o reservar tu primera sesión gratuita.
							</p>
						</div>

						<div>
							<WhatsAppLink>
								<Icon name="whatsapp" class="size-7" aria-hidden="true" />
								Escribir por WhatsApp
								<Icon
									name="arrow-right"
									class="size-5 text-accent"
									aria-hidden="true"
								/>
							</WhatsAppLink>
						</div>
					</div>

					<div class="relative md:h-40 w-full">
						<div
							class="md:absolute z-10 md:left-1/2 md:-translate-x-1/2 md:top-10 bg-surface py-6 md:py-8 px-4 md:px-20 w-full rounded-xs flex flex-col md:flex-row gap-y-6 items-start justify-between max-w-6xl mx-auto"
						>
							{
								contactItems.map((item) => (
									<div class="flex items-start gap-4">
										<Icon
											name={item.icon}
											class="size-6 md:size-8 text-accent"
											aria-hidden="true"
										/>
										<div>
											<p class="text-eyebrow">{item.title}</p>
											<div class="text-body text-text">
												{item.lines ? (
													item.lines.map((line) => <p>{line}</p>)
												) : (
													<a
														href={item.href}
														target={item.external ? "_blank" : undefined}
														rel={
															item.external ? "noopener noreferrer" : undefined
														}
													>
														{item.text}
													</a>
												)}
											</div>
										</div>
									</div>
								))
							}
						</div>
					</div>
				</div>
			</div>

			<div class="pt-4 md:pt-0 px-4 md:px-0 h-100 md:h-112.5">
				<iframe
					src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d6075.61906106362!2d-3.7029538!3d40.4130701!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd4228802012091b%3A0x5b588730434e9bca!2sCalle%20de%20los%20Ca%C3%B1izares%2C%203%2C%20Centro%2C%2028012%20Madrid%2C%20Espa%C3%B1a!5e0!3m2!1ses-419!2sar!4v1779226540583!5m2!1ses-419!2sar"
					title="Mapa de ubicación de Box 28012 en Madrid"
					width="100%"
					height="100%"
					style="border:0;"
					allowfullscreen=""
					loading="lazy"
					referrerpolicy="no-referrer-when-downgrade"
					class="grayscale"></iframe>
			</div>
		</section>

		<!-- FIXED LEFT TITLE -->
		<div
			aria-hidden="true"
			class="hidden fixed left-0 bottom-24 transform -rotate-90 md:flex items-center gap-2"
		>
			<span class="text-muted font-serif text-xs uppercase"
				>{businessInfo.name}</span
			>
			<div class="h-0.5 bg-muted w-10"></div>
		</div>
	</div>

	<!-- FOOTER -->
	<div class="pt-20 md:pt-30">
		<footer class="bg-black/40">
			<div class="max-w-7xl mx-auto px-4 md:px-10 py-10 md:py-16">
				<div class="grid gap-10 md:gap-16 lg:grid-cols-[1.15fr_1fr]">
					<div class="space-y-6">
						<div>
							<p
								class="font-serif text-3xl md:text-4xl tracking-[-0.04em] uppercase"
							>
								{businessInfo.name}
							</p>
							<p class="text-eyebrow tracking-[0.28em]">
								{businessInfo.city}
							</p>
						</div>

						<p class="text-body max-w-md">
							Entrenamiento funcional en grupos reducidos en Madrid centro.
						</p>
					</div>

					<div class="flex flex-col justify-between gap-10">
						<div class="grid gap-6 md:gap-10 sm:grid-cols-2">
							<div>
								<p class="text-eyebrow">Dirección</p>
								<p class="text-body mt-3">
									{businessInfo.addressLine1}<br />
									{businessInfo.postalCode} Madrid
								</p>
							</div>

							<div>
								<p class="text-eyebrow">Contacto</p>
								<div class="text-body mt-3 space-y-2">
									<WhatsAppLink
										class="block justify-start md:justify-center"
										variant="ghost">{businessInfo.phone}</WhatsAppLink
									>
									<a
										class="block"
										target="_blank"
										rel="noopener noreferrer"
										href={businessInfo.instagramUrl}
									>
										{businessInfo.instagramHandle}
									</a>
								</div>
							</div>
						</div>

						<div
							class="flex flex-col gap-6 border-t border-white/10 pt-6 sm:flex-row sm:items-center sm:justify-between"
						>
							<WhatsAppLink
								class="font-medium text-base flex items-center gap-3 justify-start"
								variant="ghost"
							>
								Primera sesión gratuita
								<Icon
									name="arrow-right"
									class="size-6 text-accent"
									aria-hidden="true"
								/>
							</WhatsAppLink>

							<p class="text-xs text-muted">
								© 2026 Box 28012 · Todos los derechos reservados
							</p>
						</div>
					</div>
				</div>
			</div>

			<div
				class="relative flex h-60 md:h-86 items-center justify-center overflow-hidden"
			>
				<div
					class="absolute inset-0 bg-[url('/images/mosaic-v2.webp')] bg-size-[240px_240px] md:bg-size-[340px_340px] bg-center bg-repeat"
				>
				</div>

				<div class="absolute inset-0 bg-black/20"></div>

				<div
					class="absolute inset-0 bg-[linear-gradient(to_top,rgba(0,0,0,0.85)_0%,transparent_25%)]"
				>
				</div>

				<div class="relative z-10 text-center">
					<h1
						class="font-serif text-[clamp(4rem,15vw,9rem)] uppercase leading-none text-text"
					>
						{businessInfo.name}
					</h1>

					<p
						class="font-serif text-[clamp(1.25rem,3vw,3rem)] font-semibold uppercase tracking-wider leading-none text-red-500"
					>
						{businessInfo.cityShort}
					</p>
				</div>
			</div>
		</footer>
	</div>
</BaseLayout>
